{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alerts Response",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "source", "level", "message", "active", "created_at"],
    "properties": {
      "id": { "type": "string" },
      "source": { "type": "string" },
      "level": { "enum": ["info", "warning", "critical"] },
      "message": { "type": "string" },
      "active": { "type": "boolean" },
      "created_at": { "type": "string", "format": "date-time" }
    },
    "additionalProperties": false
  }
}
